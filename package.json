{
  "name": "@markdownkit/remark-mdd",
  "version": "2.2.2",
  "description": "Remark plugins and validation for MDD (Markdown Document) format - semantic document layer for professional business documents",
  "keywords": [
    "business-documents",
    "document-structure",
    "document-validation",
    "json-schema",
    "markdown",
    "mdast",
    "mdd",
    "professional-documents",
    "remark",
    "remark-plugin",
    "schema-validation",
    "semantic-markdown",
    "typescript",
    "unified"
  ],
  "homepage": "https://github.com/markdown-kit/remark-mdd#readme",
  "bugs": {
    "url": "https://github.com/markdown-kit/remark-mdd/issues"
  },
  "license": "MIT",
  "author": "Dominikos Pritis <idominikos@outlook.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/markdown-kit/remark-mdd.git"
  },
  "files": [
    "plugins/**/*.js",
    "lib/**/*.js",
    "schema/**/*.json",
    "types/**/*.d.ts",
    "index.js",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "index.js",
  "exports": {
    ".": "./index.js",
    "./plugins/document-structure": "./plugins/remark-mdd-document-structure.js",
    "./plugins/text-formatting": "./plugins/remark-mdd-text-formatting.js",
    "./plugins/mdx-conditional": "./plugins/remark-mdx-conditional.js",
    "./validator": "./lib/validator.js",
    "./plugin-validator": "./lib/plugin-validator.js",
    "./schema": "./schema/mdd-document.schema.json",
    "./schema/requirements": "./schema/document-type-requirements.json",
    "./types": "./types/mdd.d.ts"
  },
  "scripts": {
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint .",
    "lint:ci": "oxlint --deny-warnings .",
    "lint:fix": "oxlint --fix .",
    "lint:fix-unsafe": "oxlint --import-plugin node-plugin --type-aware --type-check --vitest-plugin --fix --fix-suggestions --fix-dangerously .",
    "check:fix-suggestions": "oxlint --import-plugin node-plugin --type-aware --type-check --vitest-plugin --fix --fix-suggestions . && oxfmt --write .",
    "check": "pnpm run format:check && pnpm run lint:ci",
    "test": "node --test",
    "verify:pack": "node scripts/verify-package.mjs",
    "prepublishOnly": "pnpm run test && pnpm run verify:pack"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "js-yaml": "^4.2.0",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "oxlint-tsgolint": "^0.23.0"
  },
  "peerDependencies": {
    "remark": "^15.0.1",
    "remark-mdx": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "remark-mdx": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=24.x"
  }
}
